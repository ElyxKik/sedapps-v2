# ─── Postgres ─────────────────────────────────────────────
POSTGRES_USER=sedapps
POSTGRES_PASSWORD=sedapps
POSTGRES_DB=sedapps
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://sedapps:sedapps@postgres:5432/sedapps

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-please-32-bytes-min-aaaaaaaa
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ─── Services (URLs internes Docker) ──────────────────────
CORE_API_URL=http://core-api:8000
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8001
DEPLOY_SERVICE_URL=http://deploy-service:8002
INBOX_SERVICE_URL=http://inbox-service:8003
ANALYTICS_SERVICE_URL=http://analytics-service:8004
INTERNAL_API_TOKEN=change-me-internal-token

# ─── LLM ──────────────────────────────────────────────────
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
LLM_TIMEOUT_S=120
LLM_MAX_RETRIES=2

# ─── App ──────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Deploy service ────────────────────────────────────────
DEPLOY_DRY_RUN=true
DEPLOY_BASE_DOMAIN=sedapps.cloud
DEPLOY_PUBLIC_BASE_URL=https://sedapps.cloud
DEPLOY_WORK_DIR=/tmp/sedapps-deploys
WEB_RENDERER_SOURCE=/workspace/apps/web-renderer
PAGE_SCHEMA_SOURCE=/workspace/packages/page-schema
NEXT_PUBLIC_INBOX_URL=http://localhost:8003
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8004

# ─── Inbox / Analytics ──────────────────────────────────────
INBOX_ALLOWED_ORIGINS=*
INBOX_HONEYPOT_FIELD=website_url
INBOX_MAX_FIELD_LENGTH=5000
ANALYTICS_RESPECT_DNT=true

# ─── OVH ───────────────────────────────────────────────────
OVH_ENDPOINT=ovh-eu
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_ZONE_NAME=sedapps.cloud
OVH_S3_ENDPOINT=
OVH_S3_REGION=
OVH_S3_BUCKET=
OVH_S3_ACCESS_KEY=
OVH_S3_SECRET_KEY=
OVH_S3_PUBLIC_BASE_URL=
