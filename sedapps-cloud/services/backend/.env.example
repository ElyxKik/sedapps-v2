# Backend Configuration
SEDAPPS_DATABASE_URL=postgresql://postgres:password@localhost:5432/sedapps

# Supabase Configuration (optional - overrides DATABASE_URL if set)
SEDAPPS_SUPABASE_URL=https://your-project.supabase.co
SEDAPPS_SUPABASE_KEY=your-supabase-anon-key

# JWT Configuration
SEDAPPS_JWT_SECRET=your-secret-key-change-in-production
SEDAPPS_JWT_ALGORITHM=HS256
SEDAPPS_ACCESS_TOKEN_EXPIRES_MIN=10080

# DeepSeek LLM Configuration
SEDAPPS_DEEPSEEK_API_KEY=your-deepseek-api-key
SEDAPPS_DEEPSEEK_BASE_URL=https://api.deepseek.com
SEDAPPS_DEEPSEEK_MODEL=deepseek-chat

# CORS Configuration
SEDAPPS_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
