# SedApps Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Database (SQLite for local, PostgreSQL for production)
SEDAPPS_DATABASE_URL=sqlite:///./sedapps.db
# SEDAPPS_DATABASE_URL=postgresql://user:password@localhost:5432/sedapps

# Supabase Configuration (optional, overrides DATABASE_URL)
SEDAPPS_SUPABASE_URL=
SEDAPPS_SUPABASE_KEY=

# JWT Configuration
SEDAPPS_JWT_SECRET=your-secret-key-change-in-production
SEDAPPS_JWT_ALGORITHM=HS256
SEDAPPS_ACCESS_TOKEN_EXPIRES_MIN=10080

# CORS Configuration (comma-separated)
SEDAPPS_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# ============================================
# FLUTTER CONFIGURATION
# ============================================

# API Base URL
CORE_API_BASE_URL=http://localhost:8000

# Mock Data (false = use real API)
MOCK_DATA=false

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_MESSAGING_SENDER_ID=

# Sentry (optional)
SENTRY_DSN=

# Analytics (optional)
GOOGLE_ANALYTICS_ID=

# ============================================
# NOTES
# ============================================
# - For local development, use SQLite (default)
# - For production, use Supabase PostgreSQL
# - Change JWT_SECRET in production
# - Configure CORS_ORIGINS for your domains
# - MOCK_DATA=false uses real API endpoints
